{
	"name": "n8n-nodes-pisama",
	"version": "0.5.2",
	"description": "n8n community node that forwards workflow executions to Pisama for failure detection and self-healing",
	"keywords": [
		"n8n-community-node-package",
		"pisama",
		"observability",
		"failure-detection",
		"ai-agents"
	],
	"license": "MIT",
	"homepage": "https://pisama.ai",
	"author": {
		"name": "Pisama",
		"email": "support@pisama.ai"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Pisama-AI/n8n-nodes-pisama.git"
	},
	"bugs": {
		"url": "https://github.com/Pisama-AI/n8n-nodes-pisama/issues"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"quality:complexity": "eslint nodes credentials --rule 'complexity: [\"error\", 15]'",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.statements=100 --coverage.thresholds.branches=90",
		"audit:production": "npm audit --omit=dev --audit-level=moderate",
		"prepublishOnly": "npm run build && npm run lint && npm run quality:complexity"
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PisamaApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Pisama/Pisama.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.40.3",
		"@types/node": "^20.19.43",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^9.39.5",
		"n8n-workflow": "^2.16.0",
		"prettier": "^3.9.6",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
